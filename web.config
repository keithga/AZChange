<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="AddressProxyUpstreamUrl" value="https://www.azcleanelections.gov/Custom/GetLocation" />
    <add key="AddressProxyAllowedHost" value="www.azcleanelections.gov" />
    <add key="ReverseGeocodeUpstreamUrl" value="https://nominatim.openstreetmap.org/reverse" />
    <add key="ReverseGeocodeAllowedHost" value="nominatim.openstreetmap.org" />
    <add key="ReverseGeocodeUserAgent" value="AZChange.org/1.0 (admin@AzChange.org)" />
  </appSettings>
</configuration>
